rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      // Writes only happen from Cloud Functions (Admin SDK bypasses rules),
      // so no client write access here at all.
      allow write: if false;

      match /insights/{doc} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }

      // Access tokens. Never readable from the client, ever.
      match /private/{doc} {
        allow read, write: if false;
      }
    }
  }
}
